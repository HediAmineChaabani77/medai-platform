# ===== Application =====
APP_ENV=development
APP_SECRET=change-me-in-production-min-32-chars-xxxxxxxxx
AUDIT_HMAC_KEY=audit-hmac-key-change-in-prod-xxxxxxxxxxxxxx
JWT_SECRET=jwt-secret-change-in-prod-xxxxxxxxxxxxxxxxxxxx
JWT_EXP_MINUTES=480

# ===== Database =====
DATABASE_URL=postgresql+psycopg://medai:medai@postgres:5432/medai

# ===== Vector Store =====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=medical_qa_only

# ===== LLM Local (Ollama) =====
OLLAMA_HOST=http://ollama:11434
LLM_LOCAL_MODEL=llama3.2:3b
LLM_EMBED_MODEL=nomic-embed-text

# ===== LLM Cloud (pluggable: openai, anthropic, azure, mistral, any OpenAI-compatible) =====
LLM_CLOUD_PROVIDER=openai
LLM_CLOUD_MODEL=gpt-4o-mini
LLM_CLOUD_BASE_URL=https://api.openai.com/v1
LLM_CLOUD_API_KEY=

# ===== Connectivity probe =====
CONNECTIVITY_PROBE_URL=https://1.1.1.1
CONNECTIVITY_PROBE_INTERVAL=15

# ===== Routing =====
ROUTER_LOCAL_QUEUE_THRESHOLD=5
ROUTER_TEXT_LEN_THRESHOLD=8000

# ===== Feature flags =====
FORCE_LOCAL_ONLY=true

# ===== Admin auth / MFA =====
ADMIN_AUTH_REQUIRED=true
ADMIN_MFA_REQUIRED=true
AUTH_DEV_SEED_ADMIN=true
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123
AUTH_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# ===== DMP / DPI =====
DMP_DATA_PATH=/tmp/medai_dmp/patients.json
DPI_ARCHIVE_DIR=/tmp/medai_dpi_archive
